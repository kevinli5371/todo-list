# Supabase project URL — same value as VITE_SUPABASE_URL in the frontend
# e.g. https://uetnojsjustgbtxyetoi.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Database connection (Session pooler — IPv4 friendly)
# Dashboard → Connect → Session pooler → copy URI
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173
