# =============================================================================
# Supabase: "Direct" db.*.supabase.co is IPv6-only (no IPv4 A record).
# If you get "failed to resolve host" on Mac/home Wi‑Fi, use the SESSION POOLER
# string instead: Dashboard → Connect → "Session pooler" → copy URI.
# Username is often postgres.YOUR_PROJECT_REF (not just postgres).
# =============================================================================

# --- Option A: Session pooler (IPv4-friendly) — paste full URI or use split vars ---
# DATABASE_URL=postgresql://postgres.uetnojsjustgbtxyetoi:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# (region/host from YOUR dashboard — do not copy this example host literally)

# --- Option B: Split vars (good for special characters in password) ---
# For pooler, set user to postgres.YOUR_PROJECT_ID from the Session pooler tab:
# SUPABASE_DB_HOST=aws-0-REGION.pooler.supabase.com
# SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
# SUPABASE_DB_PASSWORD=your-password
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres

# --- Direct connection (IPv6 only — often fails on IPv4-only networks) ---
# DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Project Settings → API → JWT Secret (verify tokens from the Supabase JS client)
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173
